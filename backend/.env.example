# Copia este archivo como .env y rellena con tus valores reales.
# NUNCA subas el .env real al repositorio.

# URL de conexión a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgresql://usuario:contrasena@127.0.0.1:5432/audio_platform

# Clave secreta para firmar JWT (genera una larga y aleatoria)
# Sugerencia: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
